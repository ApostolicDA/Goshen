# ── Google Cloud ──────────────────────────────────────────────────
# Path to your GCP service account JSON key ON YOUR HOST MACHINE
# Example: C:/Users/Proud/keys/goshen-sa-key.json  (Windows)
# Example: /home/proud/keys/goshen-sa-key.json      (WSL2/Linux)
GOOGLE_APPLICATION_CREDENTIALS_HOST=C:/Users/gadis/Downloads/goshen-analytics-d29d448b3d6d.json

# Your BigQuery project ID
GCP_PROJECT_ID=goshen-analytics

# Your BigQuery dataset name
BQ_DATASET=analytics

